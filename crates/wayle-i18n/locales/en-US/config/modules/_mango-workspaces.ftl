### Wayle Configuration - Mango Workspaces Module

## Mango Workspaces Module Configuration

settings-modules-mango-workspaces-hide-empty = Hide Empty
    .description = Hide tags with no clients unless they are active

settings-modules-mango-workspaces-min-tag-count = Minimum Tags
    .description = Always show tags up to this index, even when empty

settings-modules-mango-workspaces-display-mode = Display Mode
    .description = What identifies each tag (label, icon, or none)

settings-modules-mango-workspaces-divider = Divider
    .description = Text between the tag label and its application icons

settings-modules-mango-workspaces-app-icons-show = Show App Icons
    .description = Display an application icon per client on each tag

settings-modules-mango-workspaces-app-icons-dedupe = Deduplicate Icons
    .description = Show one icon per application instead of one per client

settings-modules-mango-workspaces-app-icons-fallback = Fallback Icon
    .description = Icon for clients not matched by app-icon-map

settings-modules-mango-workspaces-app-icons-empty = Empty Icon
    .description = Icon shown when a tag has no clients

settings-modules-mango-workspaces-icon-gap = Icon Gap
    .description = Spacing between application icons

settings-modules-mango-workspaces-icon-size = Icon Size
    .description = Scale multiplier for application icons (0.25-3.0)

settings-modules-mango-workspaces-app-icon-map = App Icon Map
    .description = Client app id or title to icon mappings

settings-modules-mango-workspaces-tag-map = Tag Map
    .description = Per-tag icon and color overrides, keyed by tag index

settings-modules-mango-workspaces-urgent-show = Show Urgent
    .description = Pulse animation on tags with urgent clients

settings-modules-mango-workspaces-urgent-mode = Urgent Mode
    .description = Pulse the whole tag or only the urgent application

settings-modules-mango-workspaces-active-indicator = Active Indicator
    .description = Visual style for the active tag

settings-modules-mango-workspaces-tag-padding = Tag Padding
    .description = Padding along the bar direction

settings-modules-mango-workspaces-label-size = Label Size
    .description = Scale multiplier for tag labels (0.25-3.0)

settings-modules-mango-workspaces-active-color = Active Color
    .description = Color for the active tag label

settings-modules-mango-workspaces-occupied-color = Occupied Color
    .description = Color for tags that hold clients

settings-modules-mango-workspaces-empty-color = Empty Color
    .description = Color for empty tags

settings-modules-mango-workspaces-container-bg-color = Container Background
    .description = Background color for the tag container

settings-modules-mango-workspaces-border-show = Show Border
    .description = Display border around the tag container

settings-modules-mango-workspaces-border-color = Border Color
    .description = Border color for the tag container

settings-modules-mango-workspaces-left-click = Left Click
    .description = Action on left click

settings-modules-mango-workspaces-middle-click = Middle Click
    .description = Action on middle click

settings-modules-mango-workspaces-right-click = Right Click
    .description = Action on right click

settings-modules-mango-workspaces-scroll-up = Scroll Up
    .description = Action on scroll up

settings-modules-mango-workspaces-scroll-down = Scroll Down
    .description = Action on scroll down
